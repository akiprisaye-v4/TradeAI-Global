{
  "manifest_version": 3,
  "name": "Amazon Profit Pro - Product Extractor",
  "version": "1.0.0",
  "description": "Extrait les données des produits Amazon pour Amazon Profit Pro",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.amazon.fr/*",
    "https://*.amazon.com/*",
    "https://*.amazon.de/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.it/*",
    "https://*.amazon.es/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.fr/*",
        "https://*.amazon.com/*",
        "https://*.amazon.de/*",
        "https://*.amazon.co.uk/*",
        "https://*.amazon.it/*",
        "https://*.amazon.es/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
